{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "ltx-video-2b-v0.9.5.safetensors" },
    "_meta": { "title": "Load LTX-Video checkpoint" }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": { "clip_name": "t5xxl_fp16.safetensors", "type": "ltxv" },
    "_meta": { "title": "Load T5 text encoder" }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "a red fox running through snow, cinematic", "clip": ["2", 0] },
    "_meta": { "title": "Prompt" }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "blurry, low quality, watermark", "clip": ["2", 0] },
    "_meta": { "title": "Negative prompt" }
  },
  "5": {
    "class_type": "EmptyLTXVLatentVideo",
    "inputs": { "width": 768, "height": 512, "length": 97, "batch_size": 1 },
    "_meta": { "title": "Video latent" }
  },
  "6": {
    "class_type": "LTXVConditioning",
    "inputs": { "positive": ["3", 0], "negative": ["4", 0], "frame_rate": 25.0 },
    "_meta": { "title": "LTXV conditioning" }
  },
  "7": {
    "class_type": "LTXVScheduler",
    "inputs": { "steps": 30, "max_shift": 2.05, "base_shift": 0.95, "stretch": true, "terminal": 0.1 },
    "_meta": { "title": "LTXV scheduler" }
  },
  "8": {
    "class_type": "KSamplerSelect",
    "inputs": { "sampler_name": "euler" },
    "_meta": { "title": "Sampler" }
  },
  "9": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["1", 0], "add_noise": true, "noise_seed": 42, "cfg": 3.0,
      "positive": ["6", 0], "negative": ["6", 1],
      "sampler": ["8", 0], "sigmas": ["7", 0], "latent_image": ["5", 0]
    },
    "_meta": { "title": "Sample" }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["9", 0], "vae": ["1", 2] },
    "_meta": { "title": "Decode" }
  },
  "11": {
    "class_type": "CreateVideo",
    "inputs": { "images": ["10", 0], "fps": 25.0 },
    "_meta": { "title": "Create video" }
  },
  "12": {
    "class_type": "SaveVideo",
    "inputs": { "video": ["11", 0], "filename_prefix": "video/superchat", "format": "mp4", "codec": "h264" },
    "_meta": { "title": "Save video" }
  }
}
