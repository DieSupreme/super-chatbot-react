{
  "label": "LTX-Video — text to video",
  "backend": "comfy",
  "controls": {
    "prompt":   { "node": "3", "input": "text", "type": "text" },
    "negative": { "node": "4", "input": "text", "type": "text" },
    "seed":     { "node": "9", "input": "noise_seed", "type": "seed" },
    "steps":    { "node": "7", "input": "steps",  "type": "int",   "default": 30,  "min": 1,   "max": 100 },
    "cfg":      { "node": "9", "input": "cfg",    "type": "float", "default": 3.0, "min": 0,   "max": 20, "step": 0.1 },
    "width":    { "node": "5", "input": "width",  "type": "int",   "default": 768, "min": 256, "max": 1280, "step": 32 },
    "height":   { "node": "5", "input": "height", "type": "int",   "default": 512, "min": 256, "max": 1280, "step": 32 },
    "frames":   { "node": "5", "input": "length", "type": "int",   "default": 97,  "min": 9,   "max": 257, "step": 8 },
    "fps":      { "targets": [ { "node": "6", "input": "frame_rate" }, { "node": "11", "input": "fps" } ],
                  "type": "float", "default": 25, "min": 1, "max": 60 }
  }
}
